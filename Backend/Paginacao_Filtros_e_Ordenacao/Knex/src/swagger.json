{
  "openapi": "3.0.0",
  "info": {
    "title": "API Gestão Escolar - Knex.js",
    "description": "Documentação da API desenvolvida com Express, Knex.js e PostgreSQL no Docker, incluindo Paginação, Filtros e Ordenação.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Servidor Local"
    }
  ],
  "paths": {
    "/alunos": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Lista alunos com paginação, filtros e ordenação",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por nome ou email", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "description": "Coluna para ordenação (id, nome, email)", "schema": { "type": "string", "default": "id" } },
          { "name": "order", "in": "query", "description": "Ordem da listagem", "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" } }
        ],
        "responses": {
          "200": { "description": "Lista de alunos retornada com sucesso" }
        }
      },
      "post": {
        "tags": ["Alunos"],
        "summary": "Cadastra um novo aluno",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Aluno" }
            }
          }
        },
        "responses": {
          "201": { "description": "Aluno criado com sucesso" },
          "400": { "description": "Erro na requisição" }
        }
      }
    },
    "/alunos/{id}": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Busca um aluno específico por ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Aluno encontrado" },
          "404": { "description": "Aluno não encontrado" }
        }
      },
      "put": {
        "tags": ["Alunos"],
        "summary": "Atualiza dados de um aluno",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } }
        },
        "responses": { "200": { "description": "Atualizado com sucesso" } }
      },
      "delete": {
        "tags": ["Alunos"],
        "summary": "Remove um aluno do sistema",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "Removido com sucesso" } }
      }
    },
    "/cursos": {
      "get": { 
        "tags": ["Cursos"], 
        "summary": "Lista cursos com paginação, filtros e ordenação",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por nome do curso", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "description": "Coluna para ordenação (id, nome, cargaHoraria)", "schema": { "type": "string", "default": "id" } },
          { "name": "order", "in": "query", "description": "Ordem da listagem", "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" } }
        ],
        "responses": { "200": { "description": "Sucesso" } }
      },
      "post": {
        "tags": ["Cursos"],
        "summary": "Cria um novo curso",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Curso" }
            }
          }
        },
        "responses": { "201": { "description": "Curso criado" } }
      }
    },
    "/cursos/{id}": {
      "get": { "tags": ["Cursos"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Sucesso" } } },
      "put": { "tags": ["Cursos"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Curso" } } } }, "responses": { "200": { "description": "Atualizado" } } },
      "delete": { "tags": ["Cursos"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }], "responses": { "204": { "description": "Removido" } } }
    },
    "/matriculas": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Lista geral de todas as matrículas com paginação",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por ID (Aluno ou Curso)", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "description":"Ordem da listagem", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "ASC" } }
        ],
        "responses": { "200": { "description": "Sucesso" } }
      }
    },
    "/matricular": {
      "post": {
        "tags": ["Matrículas"],
        "summary": "Matricular aluno",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "alunoId": { "type": "integer" },
                  "cursoId": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Matriculado com sucesso" }
        }
      }
    },
    "/listar-matriculas/{id_aluno}": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Busca todos os cursos vinculados a um aluno",
        "parameters": [
          { "name": "id_aluno", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Lista retornada" } }
      }
    },
    "/matriculas/{id}": {
      "delete": {
        "tags": ["Matrículas"],
        "summary": "Cancela uma matrícula por ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "Removido" } }
      }
    }
  },
  "components": {
    "schemas": {
      "Aluno": {
        "type": "object",
        "required": ["nome", "email"],
        "properties": {
          "nome": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "Curso": {
        "type": "object",
        "required": ["nome", "cargaHoraria"],
        "properties": {
          "nome": { "type": "string" },
          "cargaHoraria": { "type": "integer" }
        }
      }
    }
  }
}