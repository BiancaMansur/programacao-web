{
  "openapi": "3.0.0",
  "info": {
    "title": "API Escola - TypeORM",
    "description": "Documentação da API com TypeORM, incluindo Paginação, Filtros e Ordenação.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/alunos": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Lista alunos com paginação e filtros",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por nome ou e-mail", "schema": { "type": "string" } }, 
          { "name": "sort", "in": "query", "description": "Coluna de ordenação (id, nome, email)", "schema": { "type": "string", "default": "id" } },
          { "name": "order", "in": "query", "description": "Ordem da listagem", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "ASC" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Alunos"],
        "summary": "Cria um aluno",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AlunoInput" } } }
        },
        "responses": { "201": { "description": "OK" } }
      }
    },
    "/api/alunos/{id}": {
      "get": {
        "tags": ["Alunos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Alunos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AlunoInput" } } }
        },
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Alunos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "OK" } }
      }
    },
    "/api/cursos": {
      "get": {
        "tags": ["Cursos"],
        "summary": "Lista cursos com paginação e filtros",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por  nome do curso", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "description": "Coluna para ordenação (id, nome, cargaHoraria)", "schema": { "type": "string", "default": "id" } },
          { "name": "order", "in": "query", "description": "Ordem da listagem", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "ASC" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Cursos"],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CursoInput" } } }
        },
        "responses": { "201": { "description": "OK" } }
      }
    },
    "/api/cursos/{id}": {
      "get": {
        "tags": ["Cursos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Cursos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CursoInput" } } }
        },
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Cursos"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "OK" } }
      }
    },
    "/api/matriculas": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Lista matrículas com paginação",
        "parameters": [
          { "name": "page", "in": "query", "description": "Número da página", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "description": "Registros por página", "schema": { "type": "integer", "default": 10 } },
          { "name": "filter", "in": "query", "description": "Filtro por ID (Aluno ou Curso)", "schema": { "type": "string" } },
          { "name": "order", "in": "query", "description":"Ordem da listagem", "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "ASC" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "tags": ["Matrículas"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "alunoId": { "type": "integer" },
                  "cursoId": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "OK" } }
      }
    },
    "/api/matriculas/{id}": {
      "delete": {
        "tags": ["Matrículas"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "OK" } }
      }
    },
    "/api/listar-matriculas/{id_aluno}": {
      "get": {
        "tags": ["Matrículas"],
        "parameters": [{ "name": "id_aluno", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "OK" } }
      }
    }
  },
  "components": {
    "schemas": {
      "AlunoInput": {
        "type": "object",
        "properties": {
          "nome": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "CursoInput": {
        "type": "object",
        "properties": {
          "nome_curso": { "type": "string" },
          "carga_horaria": { "type": "integer" }
        }
      }
    }
  }
}